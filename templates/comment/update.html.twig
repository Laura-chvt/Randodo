{% extends 'base.html.twig' %}

{% block title %}Modifier mon avis{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h3 fw-bold mb-4">Modifier mon avis sur {{ hike.name }}</h1>
            
            <div class="card shadow-sm p-4 rounded-4 border-0">
                {{ form_start(updateForm) }}
                    <div class="mb-3">
                        {{ form_widget(updateForm.content) }}
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning rounded-pill px-4">Enregistrer les modifications</button>
                        <a href="{{ path('app_hike_show', {'id': hike.id}) }}" class="btn btn-light rounded-pill px-4">Annuler</a>
                    </div>
                {{ form_end(updateForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}