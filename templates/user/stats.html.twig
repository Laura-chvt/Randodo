{% extends 'base.html.twig' %}

{% block title %}Statistiques - Page administrateur{% endblock %}

{% block body %}
<main class="container flex-grow-1 my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold h2 m-0"><a href="{{ path('app_user_index') }}" class="text-decoration-none text-reset">Tableau de bord</a></h1>
        <h1 class="fw-bold h2 m-0"><a href="{{ path('app_user_stats') }}" class="text-decoration-none text-reset">Statistiques</a></h1>
    </div>

    <section class="admin-card">
        <h3 class="h5 fw-bold mb-4"><i class="bi bi-bar-chart text-muted me-2"></i>Statistiques</h3>
        
        <div class="table-cosy-container table-responsive">
            <table class="table table-cosy align-middle">
                <thead>
                    <tr>
                        <th scope="col">Randonnée</th>
                        <th scope="col">Nombre en favoris</th>
                        <th scope="col">Nombre faite</th>
                    </tr>
                </thead>
                <tbody>
                    {% for stat in statsList %}
                    <tr>
                        <td class="text-brown">{{ stat.hike_name }}</td>
                        <td>
                            <span class="badge bg-light text-danger border border-danger-subtle">
                                <i class="bi bi-heart-fill"></i> {{ stat.fav_count }}
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-light text-success border border-success-subtle">
                                <i class="bi bi-check-circle-fill"></i> {{ stat.done_count }}
                            </span>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">Aucune donnée disponible pour le moment.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</main>
{% endblock %}