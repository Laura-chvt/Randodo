{% extends 'base.html.twig' %}

{% block title %}Dashboard - Page administrateur{% endblock %}

{% block body %}
<main class="container flex-grow-1 my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold h2 m-0"><a href="{{ path('app_user_index') }}" class="text-decoration-none text-reset">Tableau de bord</a></h1>
        <h1 class="fw-bold h2 m-0"><a href="{{ path('app_user_stats') }}" class="text-decoration-none text-reset">Statistiques</a></h1>
    </div>

    <section class="admin-card">
        <h3 class="h5 fw-bold mb-4"><i class="bi bi-signpost-2 text-muted me-2"></i>Ajouter une nouvelle zone de randonnées</h3>
        {{ form_start(locationCreateFormType, {'attr': {'class': 'row g-3 align-items-end'}}) }}
        <div class="col-md-6">
            {{ form_label(locationCreateFormType.name, 'Nom de la zone', {'label_attr': {'class': 'form-label text-muted small mb-1'}}) }}
            {{ form_widget(locationCreateFormType.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Massif du Donon'}}) }}
            {{ form_label(locationCreateFormType.gps, 'Coordonnées GPS', {'label_attr': {'class': 'form-label text-muted small mb-1'}}) }}
            {{ form_widget(locationCreateFormType.gps, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 48.2500, 7.4500'}}) }}
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-brown w-100">Ajouter</button>
        </div>
        {{ form_end(locationCreateFormType) }}
    </section>

    <section class="admin-card">
        <h3 class="h5 fw-bold mb-4"><i class="bi bi-people text-muted me-2"></i>Gestion des utilisateurs</h3>
        
        <div class="table-cosy-container table-responsive">
            <table class="table table-cosy align-middle text-nowrap mb-0">
                <thead>
                    <tr>
                        <th scope="col">Utilisateur</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rôle</th>
                        <th scope="col">Date d'inscription</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in userList %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="fw-bold">{{ user.firstname }} {{ user.name }}</div>
                            </div>
                        </td>
                        <td class="text-muted">{{ user.email }}</td>
                        <td>
                            <form action="{{ path('app_user_change_role', {'id': user.id}) }}" method="POST" class="d-flex align-items-center m-0">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('change_role' ~ user.id) }}">
                                
                                <select name="new_role" class="form-select form-select-sm w-auto me-2">
                                    <option value="ROLE_USER" {% if 'ROLE_USER' in user.roles %}selected{% endif %}>Utilisateur</option>
                                    <option value="ROLE_MODO" {% if 'ROLE_MODO' in user.roles %}selected{% endif %}>Modérateur</option>
                                    <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in user.roles %}selected{% endif %}>Administrateur</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-save px-2" title="Sauvegarder le rôle">Modifier</button>
                            </form>
                        </td>
                        <td class="text-muted small">{{ user.createdAt|date('d/m/Y') }}</td>
                        <td class="text-end">
                            <form action="{{ path('app_user_delete', {'id': user.id}) }}" method="POST" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce compte ?');">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_user' ~ user.id) }}">
                                <button type="submit" class="btn btn-sm btn-delete px-3" title="Supprimer l'utilisateur">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</main>
{% endblock %}
