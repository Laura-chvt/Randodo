{% extends 'base.html.twig' %}

{% block title %}Page administrateur{% endblock %}

{% block body %}
<main class="container flex-grow-1 my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold h2 m-0">Tableau de bord</h1>
    </div>

    <section class="admin-card">
        <h3 class="h5 fw-bold mb-3"><i class="bi bi-map text-muted me-2"></i>Ajouter une nouvelle zone de randonnées</h3>
        <form class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Nom de la zone (ex: Massif du Donon)</label>
                <input type="text" class="form-control" placeholder="Saisir le nom de la zone...">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-brown w-100"><i class="bi bi-plus-lg"></i> Ajouter</button>
            </div>
        </form>
    </section>

    <section class="admin-card">
        <h3 class="h5 fw-bold mb-4"><i class="bi bi-people text-muted me-2"></i>Gestion des utilisateurs</h3>
        
        <div class="table-cosy-container table-responsive">
            <table class="table table-cosy align-middle">
                <thead>
                    <tr>
                        <th scope="col">Utilisateur</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rôle</th>
                        <th scope="col">Date d'inscription</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in userList %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="fw-bold">{{ user.firstname }} {{ user.name }}</div>
                            </div>
                        </td>
                        <td class="text-muted">{{ user.email }}</td>
                        <td>
                            <select class="form-select form-select-sm w-auto">
                                <option value="ROLE_USER" selected>Utilisateur</option>
                                <option value="ROLE_GUIDE">Guide Local</option>
                                <option value="ROLE_ADMIN">Administrateur</option>
                            </select>
                        </td>
                        <td class="text-muted small"></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-save px-3 me-1" title="Sauvegarder les modifications"><i class="bi bi-check2"></i></button>
                            <button class="btn btn-sm btn-delete px-3" title="Supprimer l'utilisateur"><i class="bi bi-trash3"></i></button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</main>
{% endblock %}
