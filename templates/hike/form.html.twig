{% extends 'base.html.twig' %}

{% block title %}Ajouter/modifier une randonnée{% endblock %}

{% block body %}

<div class="row justify-content-center mt-5">

    <div class="col-12 col-md-6 col-lg-5">

        <div class="card shadow-sm">

            <div class="card-header">
                {% if createForm.vars.value.id is null %}
                <h3>Ajouter une randonnée</h3>
                {% else %}
                <h3>Modifier une randonnée</h3>
                {% endif %}
            </div>

            <div class="card-body">

                {{ form(createForm) }}
                
            </div>
        </div>

    </div>

</div>

{% endblock %}